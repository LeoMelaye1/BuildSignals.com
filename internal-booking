<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Internal Sales Calendar | Build Signals</title>
    <style>
        /* 1. Reset & Base Styles */
        body {
            margin: 0;
            padding: 0;
            background-color: #f4f6f8; /* Light gray "Dashboard" background */
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #333;
            display: flex;
            justify-content: center;
            min-height: 100vh;
        }

        /* 2. The "Card" Container */
        .dashboard-container {
            background: #ffffff;
            width: 100%;
            max-width: 900px; /* Limits width so it doesn't stretch on big screens */
            margin-top: 40px;
            margin-bottom: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08); /* Soft drop shadow */
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* 3. The Header Section */
        .header {
            padding: 25px 30px;
            border-bottom: 1px solid #eaeaea;
            background-color: #fff;
        }

        .header h1 {
            margin: 0;
            font-size: 20px;
            font-weight: 600;
            color: #111;
        }

        .header p {
            margin: 5px 0 0 0;
            font-size: 14px;
            color: #666;
        }

        /* 4. The Calendar Wrapper */
        .calendar-wrapper {
            width: 100%;
            height: 100%;
            min-height: 600px; /* Ensures it doesn't collapse while loading */
        }
    </style>
</head>
<body>

    <div class="dashboard-container">
        <div class="header">
            <h1>📅 Internal Booking Terminal</h1>
            <p>Select a time slot below to lock in the partner appointment.</p>
        </div>

        <div class="calendar-wrapper">
            <iframe 
                src="https://api.leadconnectorhq.com/widget/booking/lbjRU9nZM557muKsK2o2" 
                style="width: 100%; border:none; overflow: hidden; min-height: 700px;" 
                scrolling="no" 
                id="lbjRU9nZM557muKsK2o2_1770885718719">
            </iframe>
        </div>
    </div>

    <script src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>

</body>
</html>
