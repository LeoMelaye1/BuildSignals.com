<style>
  :root {
    --navy: #0D1B3E;
    --gold: #C9A84C;
    --card: #1A2545;
    --card2: #111E38;
    --card3: #0F1A34;
    --white: #F4F6FA;
    --body: #C5D3E8;
    --muted: #7A90B8;
    --green: #2A8C5A;
    --amber: #B87A10;
    --blue: #2D6FAD;
    --red: #8C3030;
    --purple: #5A3A8C;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--navy); color: var(--white); font-family: 'IBM Plex Sans', sans-serif; }

  /* HEADER */
  header { background: var(--card2); border-bottom: 1px solid rgba(201,168,76,.25); padding: 22px 48px; display: flex; justify-content: space-between; align-items: center; }
  .logo { font-family: 'Playfair Display', serif; font-size: 13px; color: var(--gold); letter-spacing: 3px; text-transform: uppercase; }
  .header-meta { display: flex; gap: 20px; align-items: center; }
  .tag { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--muted); letter-spacing: 1.5px; text-transform: uppercase; }
  .tag.highlight { color: var(--gold); background: rgba(201,168,76,.08); border: 1px solid rgba(201,168,76,.2); padding: 4px 10px; }

  /* HERO */
  .hero { padding: 52px 48px 36px; max-width: 1200px; margin: 0 auto; }
  .eyebrow { font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: 3px; color: var(--gold); text-transform: uppercase; margin-bottom: 14px; }
  h1 { font-family: 'Playfair Display', serif; font-size: 48px; font-weight: 900; line-height: 1.1; margin-bottom: 18px; }
  h1 em { color: var(--gold); font-style: normal; }
  .hero-sub { font-size: 14px; color: var(--body); line-height: 1.7; max-width: 600px; margin-bottom: 36px; font-weight: 300; }

  /* STAT BAR */
  .stats { display: flex; border: 1px solid rgba(201,168,76,.2); max-width: 900px; margin-bottom: 0; }
  .stat { flex: 1; padding: 18px 22px; border-right: 1px solid rgba(201,168,76,.12); }
  .stat:last-child { border-right: none; }
  .stat-n { font-family: 'Playfair Display', serif; font-size: 28px; color: var(--gold); font-weight: 700; line-height: 1; margin-bottom: 5px; }
  .stat-l { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1.5px; font-family: 'IBM Plex Mono', monospace; }

  /* SECTION */
  .section { max-width: 1200px; margin: 0 auto; padding: 48px 48px 0; }
  .section-head { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }
  .section-label { font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); }
  .section-line { flex: 1; height: 1px; background: rgba(255,255,255,.07); }
  .section-count { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--muted); }

  /* TABLE STYLE BID LIST */
  .bid-table { width: 100%; border-collapse: collapse; }
  .bid-table thead tr { border-bottom: 1px solid rgba(201,168,76,.2); }
  .bid-table th { font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); padding: 10px 14px; text-align: left; font-weight: 400; }
  .bid-table tbody tr { border-bottom: 1px solid rgba(255,255,255,.05); transition: background .15s; cursor: default; }
  .bid-table tbody tr:hover { background: rgba(255,255,255,.02); }
  .bid-table td { padding: 14px 14px; vertical-align: top; }

  .col-status { width: 100px; }
  .col-project { width: 260px; }
  .col-agency { width: 180px; }
  .col-trade { width: 110px; }
  .col-type { width: 90px; }
  .col-value { width: 110px; text-align: right; }
  .col-contact { }

  .project-name { font-size: 13px; font-weight: 600; color: var(--white); line-height: 1.35; margin-bottom: 3px; }
  .project-note { font-size: 11px; color: var(--muted); line-height: 1.5; font-weight: 300; }
  .agency-name { font-size: 12px; color: var(--body); font-weight: 400; }
  .agency-dist { font-size: 10px; color: var(--muted); font-family: 'IBM Plex Mono', monospace; }
  .val { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--body); text-align: right; }
  .contact-val { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--gold); line-height: 1.6; }

  /* BADGES */
  .badge { display: inline-block; font-family: 'IBM Plex Mono', monospace; font-size: 8.5px; letter-spacing: 1px; text-transform: uppercase; padding: 2px 7px; font-weight: 500; white-space: nowrap; }
  .b-live { background: rgba(42,140,90,.15); color: #4abe82; border: 1px solid rgba(42,140,90,.25); }
  .b-hot { background: rgba(180,50,50,.15); color: #e87070; border: 1px solid rgba(180,50,50,.25); }
  .b-soon { background: rgba(201,132,10,.12); color: #e8a832; border: 1px solid rgba(201,132,10,.2); }
  .b-pipe { background: rgba(80,110,180,.12); color: #8ab0e8; border: 1px solid rgba(80,110,180,.2); }
  .b-active { background: rgba(100,100,180,.12); color: #aaaae8; border: 1px solid rgba(100,100,180,.2); }

  .t-concrete { background: rgba(201,168,76,.1); color: var(--gold); border: 1px solid rgba(201,168,76,.2); }
  .t-carp { background: rgba(160,120,200,.1); color: #c4a0e8; border: 1px solid rgba(160,120,200,.2); }
  .t-both { background: rgba(200,120,60,.1); color: #e8a070; border: 1px solid rgba(200,120,60,.2); }

  .type-sub { background: rgba(42,140,90,.1); color: #4abe82; border: 1px solid rgba(42,140,90,.2); }
  .type-prime { background: rgba(45,111,173,.1); color: #6aaade; border: 1px solid rgba(45,111,173,.2); }
  .type-either { background: rgba(140,58,140,.1); color: #d888e8; border: 1px solid rgba(140,58,140,.2); }

  /* GC NETWORK SECTION */
  .gc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  .gc-card { background: var(--card); padding: 24px 26px; border-top: 2px solid var(--gold); }
  .gc-name { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .gc-loc { font-family: 'IBM Plex Mono', monospace; font-size: 9px; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px; }
  .gc-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 10px; }
  .gc-note { font-size: 12px; color: var(--body); line-height: 1.6; font-weight: 300; margin-bottom: 12px; }
  .gc-contact { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--gold); }

  /* PORTAL GRID */
  .portal-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; }
  .portal-card { background: var(--card2); padding: 18px 20px; }
  .portal-icon { font-size: 18px; margin-bottom: 8px; }
  .portal-name { font-size: 12px; font-weight: 600; color: var(--white); margin-bottom: 5px; }
  .portal-desc { font-size: 11px; color: var(--muted); line-height: 1.5; font-weight: 300; }
  .portal-url { font-family: 'IBM Plex Mono', monospace; font-size: 9px; color: var(--gold); margin-top: 8px; word-break: break-all; }

  /* CALLOUT */
  .callout { background: rgba(201,168,76,.05); border: 1px solid rgba(201,168,76,.2); padding: 22px 28px; margin: 32px 0; display: flex; gap: 16px; align-items: flex-start; }
  .callout-icon { font-size: 20px; flex-shrink: 0; }
  .callout-text { font-size: 13px; color: var(--body); line-height: 1.7; font-weight: 300; }
  .callout-text strong { color: var(--gold); font-weight: 500; }

  /* DIVIDER */
  .spacer { height: 48px; }

  footer { background: var(--card2); border-top: 1px solid rgba(201,168,76,.15); padding: 18px 48px; display: flex; justify-content: space-between; align-items: center; margin-top: 48px; }
  .footer-l { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--muted); }
  .footer-l span { color: var(--gold); }
  .footer-r { font-size: 11px; color: rgba(158,179,212,.4); font-style: italic; }

  @media (max-width: 900px) {
    header, .hero, .section { padding-left: 24px; padding-right: 24px; }
    h1 { font-size: 32px; }
    .gc-grid, .portal-grid { grid-template-columns: 1fr; }
    .stats { flex-wrap: wrap; }
    .bid-table { font-size: 11px; }
    .col-project { width: auto; }
    footer { flex-direction: column; gap: 8px; text-align: center; padding: 14px 24px; }
  }
</style>
</head>
